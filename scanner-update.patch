+/* ──────────────────────── malware classification ──────────────────────── */
+static malware_type_t classify_malware(const char *cmdline, const char *exe) {
+    const char *cmd = cmdline ? cmdline : "";
+    const char *ex  = exe ? exe : "";
+
+    /* cryptominer signatures */
+    if (strstr(cmd, "xmrig") || strstr(cmd, "minerd") || strstr(cmd, "stratum") ||
+        strstr(cmd, "pool.") || strstr(cmd, "mine.") || strstr(cmd, "kdevtmpfsi") ||
+        strstr(cmd, "kinsing") || strstr(cmd, "cryptonight") || strstr(cmd, "monero") ||
+        strstr(cmd, "nanopool") || strstr(cmd, "nicehash") || strstr(cmd, "hashrate") ||
+        strstr(cmd, "rig.") || strstr(cmd, "watchbog") || strstr(cmd, "minergate") ||
+        strstr(ex,  "xmrig") || strstr(ex, "kdevtmpfsi") || strstr(ex, "kinsing"))
+        return MAL_CRYPTOMINER;
+
+    /* IRC bot */
+    if (strstr(cmd, "irc") || strstr(cmd, "6667") || strstr(cmd, "6668") ||
+        strstr(cmd, "6669") || strstr(cmd, "undernet") || strstr(cmd, "efnet") ||
+        strstr(cmd, "dalnet"))
+        return MAL_IRC_BOT;
+
+    /* DDoS bot signatures */
+    if (strstr(cmd, "ddos") || strstr(cmd, "flood") || strstr(cmd, "udpflood") ||
+        strstr(cmd, "synflood") || strstr(cmd, "slowloris") || strstr(cmd, "hulk") ||
+        strstr(cmd, "xerxes") || strstr(cmd, "mirai") || strstr(cmd, "tsunami") ||
+        strstr(cmd, "kaiten") || strstr(cmd, "bashlite") || strstr(cmd, "gafgyt") ||
+        strstr(cmd, "qbot") || strstr(cmd, "hajime"))
+        return MAL_DDOS_BOT;
+
+    /* botnet client */
+    if (strstr(cmd, "botnet") || strstr(cmd, "bot.") || strstr(cmd, "cnc") ||
+        strstr(cmd, "command and control"))
+        return MAL_BOTNET_CLIENT;
+
+    /* RAT / meterpreter / cobalt */
+    if (strstr(cmd, "meterpreter") || strstr(cmd, "cobalt") || strstr(cmd, "metasploit") ||
+        strstr(cmd, "beacon") || strstr(cmd, "reverse_shell") || strstr(cmd, "bind_shell") ||
+        strstr(cmd, "sliver") || strstr(cmd, "empire") || strstr(cmd, "pupy") ||
+        strstr(cmd, "covenant"))
+        return MAL_RAT;
+
+    /* rootkit indicators */
+    if (strstr(cmd, "ld.so.preload") || strstr(cmd, "LD_PRELOAD") ||
+        strstr(cmd, "rootkit") || strstr(cmd, "diamorphine") || strstr(cmd, "reptile") ||
+        strstr(cmd, "jynx"))
+        return MAL_ROOTKIT;
+
+    /* web shell */
+    if (strstr(cmd, "c99.php") || strstr(cmd, "r57.php") || strstr(cmd, "b374k") ||
+        strstr(cmd, "weevely") || strstr(cmd, "webshell") || strstr(cmd, "wso.php") ||
+        strstr(cmd, "china chopper"))
+        return MAL_WEBSHELL;
+
+    /* ransomware */
+    if (strstr(cmd, "ransom") || strstr(cmd, "encrypt") || strstr(cmd, ".locked") ||
+        strstr(cmd, "bitcoin") || strstr(cmd, "wallet") || strstr(cmd, "decrypt_files"))
+        return MAL_RANSOMWARE;
+
+    /* info stealer */
+    if (strstr(cmd, "keylogger") || strstr(cmd, "stealer") || strstr(cmd, "credential") ||
+        strstr(cmd, "mimikatz") || strstr(cmd, "lazagne"))
+        return MAL_STEALER;
+
+    /* dropper / loader */
+    if ((strstr(cmd, "wget") || strstr(cmd, "curl")) &&
+        (strstr(cmd, "/tmp") || strstr(cmd, "/dev/shm") || strstr(cmd, "chmod +x") ||
+         strstr(cmd, "pastebin") || strstr(cmd, "transfer.sh") || strstr(cmd, "ix.io") ||
+         strstr(cmd, "raw.")))
+        return MAL_DROPPER;
+
+    /* proxy */
+    if (strstr(cmd, "proxy") || strstr(cmd, "socks5") || strstr(cmd, "3proxy") ||
+        strstr(cmd, "microsocks") || strstr(cmd, "gost") || strstr(cmd, "frp"))
+        return MAL_PROXY;
+
+    /* generic backdoor (base64 decode + exec, eval) */
+    if ((strstr(cmd, "base64") && (strstr(cmd, "-d") || strstr(cmd, "decode"))) ||
+        strstr(cmd, "eval ") || strstr(cmd, "exec("))
+        return MAL_BACKDOOR;
+
+    /* exe in temp is suspicious */
+    if (strstr(ex, "/tmp/") || strstr(ex, "/dev/shm/") || strstr(ex, "/var/tmp/"))
+        return MAL_SUSPICIOUS;
+
+    return MAL_UNKNOWN;
+}
