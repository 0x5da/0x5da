+static void dump_proc_open_sockets(pid_t pid) {
+    char path[MAX_PATH_LEN], link[MAX_PATH_LEN];
+    snprintf(path, sizeof(path), "/proc/%d/fd", (int)pid);
+    DIR *d = opendir(path);
+    if (!d) return;
+    struct dirent *e;
+    int sock_count = 0, file_count = 0, pipe_count = 0;
+    while ((e = readdir(d)) != NULL) {
+        if (e->d_name[0] == '.') continue;
+        char fdp[MAX_PATH_LEN];
+        snprintf(fdp, sizeof(fdp), "/proc/%d/fd/%s", (int)pid, e->d_name);
+        ssize_t L = readlink(fdp, link, sizeof(link) - 1);
+        if (L <= 0) continue;
+        link[L] = '\0';
+        if (strncmp(link, "socket:", 7) == 0) sock_count++;
+        else if (strncmp(link, "pipe:", 5) == 0) pipe_count++;
+        else file_count++;
+    }
+    closedir(d);
+    printf("      %sFDs%s:     %d sockets, %d files, %d pipes\n", C_CYN, C_RST, sock_count, file_count, pipe_count);
+}
+
+static void dump_proc_environ_flags(pid_t pid) {
+    char path[MAX_PATH_LEN], buf[8192];
+    snprintf(path, sizeof(path), "/proc/%d/environ", (int)pid);
+    FILE *f = fopen(path, "r");
+    if (!f) return;
+    size_t n = fread(buf, 1, sizeof(buf) - 1, f);
+    fclose(f);
+    buf[n] = '\0';
+    if (strstr(buf, "LD_PRELOAD"))
+        printf("      %s⚠ ENV%s:   LD_PRELOAD set %s(possible injection/rootkit)%s\n", C_RED, C_RST, C_DIM, C_RST);
+    if (strstr(buf, "LD_LIBRARY_PATH"))
+        printf("      %s⚠ ENV%s:   LD_LIBRARY_PATH set %s(library hijack risk)%s\n", C_YEL, C_RST, C_DIM, C_RST);
+    if (strstr(buf, "LD_AUDIT"))
+        printf("      %s⚠ ENV%s:   LD_AUDIT set %s(audit hooking)%s\n", C_YEL, C_RST, C_DIM, C_RST);
+}
+
+static void dump_proc_start_time(pid_t pid) {
+    char path[MAX_PATH_LEN], buf[MAX_LINE];
+    snprintf(path, sizeof(path), "/proc/%d/stat", (int)pid);
+    FILE *f = fopen(path, "r");
+    if (!f) return;
+    if (fgets(buf, sizeof(buf), f)) {
+        char *rp = strrchr(buf, ')');
+        if (rp && rp[1]) {
+            unsigned long long starttime = 0;
+            sscanf(rp + 2, " %*c %*d %*d %*d %*d %*d %*u %*u %*u %*u %*u %*u %*u %*d %*d %*d %*d %llu", &starttime);
+            long hz = sysconf(_SC_CLK_TCK);
+            if (hz > 0) {
+                FILE *uf = fopen("/proc/uptime", "r");
+                if (uf) {
+                    double uptime = 0;
+                    if (fscanf(uf, "%lf", &uptime) == 1) {
+                        time_t boot = time(NULL) - (time_t)uptime;
+                        time_t start = boot + (time_t)(starttime / (unsigned long long)hz);
+                        char tbuf[64];
+                        struct tm *tm = localtime(&start);
+                        if (tm) {
+                            strftime(tbuf, sizeof(tbuf), "%Y-%m-%d %H:%M:%S", tm);
+                            printf("      %sStarted%s: %s\n", C_CYN, C_RST, tbuf);
+                        }
+                    }
+                    fclose(uf);
+                }
+            }
+        }
+    }
+    fclose(f);
+}
+
+static void dump_proc_network_connections(pid_t pid) {
+    char path[MAX_PATH_LEN], link[MAX_PATH_LEN];
+    snprintf(path, sizeof(path), "/proc/%d/fd", (int)pid);
+    DIR *d = opendir(path);
+    if (!d) return;
+    struct dirent *e;
+    unsigned long inodes[64];
+    int inode_count = 0;
+    while ((e = readdir(d)) != NULL && inode_count < 64) {
+        if (e->d_name[0] == '.') continue;
+        char fdp[MAX_PATH_LEN];
+        snprintf(fdp, sizeof(fdp), "/proc/%d/fd/%s", (int)pid, e->d_name);
+        ssize_t L = readlink(fdp, link, sizeof(link) - 1);
+        if (L <= 0) continue;
+        link[L] = '\0';
+        if (strncmp(link, "socket:[", 8) == 0)
+            inodes[inode_count++] = (unsigned long)atol(link + 8);
+    }
+    closedir(d);
+    if (inode_count == 0) return;
+
+    FILE *f = fopen("/proc/net/tcp", "r");
+    if (!f) return;
+    char buf[MAX_LINE];
+    int shown = 0;
+    if (fgets(buf, sizeof(buf), f)) {
+        while (fgets(buf, sizeof(buf), f)) {
+            unsigned int la, lp, ra, rp, st;
+            unsigned long ino = 0;
+            if (sscanf(buf, " %*d: %8x:%4x %8x:%4x %x %*x:%*x %*x:%*lx %*x %*u %*lu %lu",
+                       &la, &lp, &ra, &rp, &st, &ino) < 6) continue;
+            for (int i = 0; i < inode_count; i++) {
+                if (inodes[i] == ino) {
+                    char lip[32], rip[32];
+                    format_ip(la, lip, sizeof(lip));
+                    format_ip(ra, rip, sizeof(rip));
+                    const char *state = "?";
+                    if (st == 1) state = "ESTABLISHED";
+                    else if (st == 10) state = "LISTEN";
+                    else if (st == 6) state = "TIME_WAIT";
+                    else if (st == 8) state = "CLOSE_WAIT";
+                    else if (st == 2) state = "SYN_SENT";
+                    printf("      %sNet%s:     %s:%u -> %s:%u [%s]\n", C_CYN, C_RST,
+                           lip, lp, rip, rp, state);
+                    if (++shown >= 8) break;
+                }
+            }
+            if (shown >= 8) break;
+        }
+    }
+    fclose(f);
+}
